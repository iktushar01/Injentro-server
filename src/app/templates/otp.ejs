<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Verify Your Access</title>
</head>
<body style="margin: 0; padding: 0; background-color: #ffffff; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; -webkit-font-smoothing: antialiased;">

<table width="100%" border="0" cellspacing="0" cellpadding="0" style="background-color: #ffffff; margin: 0; padding: 40px 20px;">
  <tr>
    <td align="center">
      
      <table width="100%" border="0" cellspacing="0" cellpadding="0" style="max-width: 380px; text-align: left;">
        
        <tr>
          <td style="padding-bottom: 24px;">
            <span style="font-size: 16px; font-weight: 600; tracking: -0.025em; color: #09090b;">
              Injentro
            </span>
          </td>
        </tr>

        <tr>
          <td style="padding-bottom: 20px;">
            <h1 style="margin: 0 0 8px 0; font-size: 18px; font-weight: 600; tracking: -0.025em; color: #09090b;">
              Verification Code
            </h1>
            <p style="margin: 0; font-size: 14px; line-height: 1.5; color: #71717a;">
              Hello <%= name %>, use the access configuration token below to authenticate and enter your workspace classroom.
            </p>
          </td>
        </tr>

        <tr>
          <td style="padding-bottom: 24px;">
            <table width="100%" border="0" cellspacing="0" cellpadding="0" style="border: 1px solid #e4e4e7; background-color: #f4f4f5; border-radius: 6px;">
              <tr>
                <td align="center" style="padding: 20px;">
                  <div style="font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace; font-size: 32px; font-weight: 700; letter-spacing: 4px; color: #09090b;">
                    <%= otp %>
                  </div>
                  <div style="margin-top: 6px; font-size: 11px; color: #71717a;">
                    Token expires in 15 minutes
                  </div>
                </td>
              </tr>
            </table>
          </td>
        </tr>


        <tr>
          <td style="border-top: 1px solid #e4e4e7; padding-top: 16px;">
            <p style="margin: 0 0 4px 0; font-size: 11px; color: #a1a1aa; line-height: 1.4;">
              If you did not initiate this authentication request, you can safely disregard this notification transmission.
            </p>
            <p style="margin: 0; font-size: 11px; color: #a1a1aa;">
              &copy; <%= new Date().getFullYear() %> Injentro &bull; Collaborative Workspace
            </p>
          </td>
        </tr>

      </table>

    </td>
  </tr>
</table>

</body>
</html>